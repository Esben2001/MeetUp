<div class="flex flex-col items-center justify-center min-h-full p-6 bg-white/80 rounded-xl mx-4 shadow-xl">
    <div class="text-center max-w-sm">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Pokemon Bingo</h1>
        <p class="text-lg text-gray-600 mb-8">Social Pokemon Hunt 🏆</p>

        <div class="bg-pokemon-blue rounded-lg p-6 shadow-sm border-2 border-pokemon-yellow mb-8">
            <h2 class="font-semibold text-white mb-3">How to play 🎮</h2>
            <ul class="text-left text-white text-sm space-y-2">
                <li>• 🔍 Find people who match the questions</li>
                <li>• 👆 Tap a square when you find a match</li>
                <li>• 🎯 Get 5 in a row to win!</li>
                <li>• 🏅 Collect badges and celebrate! 🎉</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-pokemon-red text-white font-semibold py-4 px-8 rounded-lg text-lg hover:bg-pokemon-fire transition-colors shadow-lg">
            Catch 'Em All! ⚾
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
