@using SocOps.Models

<div class="flex flex-col min-h-full">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 bg-pokemon-blue text-white border-b border-pokemon-yellow">
        <button
            @onclick="OnReset"
            class="text-white text-sm px-3 py-1.5 rounded hover:bg-pokemon-water transition-colors">
            ← Back
        </button>
        <h1 class="font-bold">Pokemon Bingo</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-gray-700 text-sm py-2 px-4 bg-white/50">
        🕵️‍♂️ Find trainers who match the questions and catch your Pokemon! ⚾
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-pokemon-yellow text-pokemon-red text-center py-2 font-semibold text-sm animate-evolve">
            🎉 POKEMON EVOLUTION! You caught a line! 🏆
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
