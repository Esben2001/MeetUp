<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-pokemon-blue rounded-xl p-6 max-w-xs w-full text-center shadow-xl animate-evolve border-4 border-pokemon-yellow">
        <div class="text-5xl mb-4">⚡🐭⚡</div>
        <h2 class="text-3xl font-bold text-pokemon-yellow mb-2">POKEMON MASTER!</h2>
        <p class="text-white mb-6">You evolved your team! 🏆</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-pokemon-red text-white font-semibold py-3 px-6 rounded-lg hover:bg-pokemon-fire transition-colors shadow-lg">
            Continue the Hunt! 🔍
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
